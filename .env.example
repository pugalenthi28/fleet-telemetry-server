# ─────────────────────────────────────────────
# Tesla Developer Application credentials
# Register at: https://developer.tesla.com
# ─────────────────────────────────────────────
TESLA_CLIENT_ID=your_client_id_here
TESLA_CLIENT_SECRET=your_client_secret_here

# The OAuth redirect URI – must match what you registered in the Tesla developer portal.
# For local testing, use your ngrok HTTPS URL.
TESLA_REDIRECT_URI=https://your-ngrok-subdomain.ngrok-free.app/auth/callback

# Tesla OAuth audience (region-specific)
# North America: https://fleet-api.prd.na.vn.cloud.tesla.com
# Europe:        https://fleet-api.prd.eu.vn.cloud.tesla.com
TESLA_AUDIENCE=https://fleet-api.prd.na.vn.cloud.tesla.com

# ─────────────────────────────────────────────
# Server settings
# ─────────────────────────────────────────────
PORT=3000

# Public HTTPS URL of this server (ngrok URL for local testing)
# Vehicles will connect to wss://SERVER_HOST for telemetry streaming
SERVER_HOST=https://your-ngrok-subdomain.ngrok-free.app

# ─────────────────────────────────────────────
# Key paths (generated by: npm run generate-keys)
# ─────────────────────────────────────────────
PRIVATE_KEY_PATH=./keys/private.pem
PUBLIC_KEY_PATH=./keys/public.pem

# ─────────────────────────────────────────────
# Vehicle-command proxy (required for apiVersion >= 3 vehicles e.g. 2024+ Model Y)
# See: https://github.com/teslamotors/vehicle-command
#
# Run locally:
#   openssl req -x509 -newkey rsa:2048 -nodes -keyout ~/vehicle-command/proxy-tls.key \
#     -out ~/vehicle-command/proxy-tls.crt -days 365 -subj "/CN=localhost"
#   ~/vehicle-command/tesla-http-proxy -key-file ./keys/private.pem \
#     -cert ~/vehicle-command/proxy-tls.crt -tls-key ~/vehicle-command/proxy-tls.key \
#     -port 4443 -verbose
# ─────────────────────────────────────────────
VEHICLE_COMMAND_PROXY_URL=https://localhost:4443

# ─────────────────────────────────────────────
# Session / security
# ─────────────────────────────────────────────
# Random 32+ char secret for PKCE state signing
SESSION_SECRET=change_me_to_a_long_random_secret_string
